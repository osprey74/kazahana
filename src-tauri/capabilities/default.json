{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        "https://*:*",
        "http://*:*"
      ]
    },
    "notification:default",
    "autostart:default",
    "dialog:default",
    "fs:default",
    "deep-link:default"
  ]
}
